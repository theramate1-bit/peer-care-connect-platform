<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Lato, Arial, Helvetica, sans-serif" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#c8d6c0" width="600">
    <mj-wrapper padding="20px">
      <mj-section padding="0">
        <mj-column width="100%" padding="0">
          <mj-raw>{{FULL_BODY}}</mj-raw>
        </mj-column>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
