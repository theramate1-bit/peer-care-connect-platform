# Agent Context Stack - Environment
# Copy to .env and adjust

# Neo4j (required for Graphiti)
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentcontext123

# Postgres (for context-service fallback store)
PG_USER=agentcontext
PG_PASSWORD=agentcontext123
PG_DB=agentcontext

# Ollama - for fully offline. Install: https://ollama.ai
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: OpenAI (if not using Ollama)
# OPENAI_API_KEY=sk-...
