SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Treatment exchange staging E2E (npm run test:exchange:e2e) — two practitioners, same rating tier, opt-in, >=60 credits
EXCHANGE_REQUESTER_EMAIL=
EXCHANGE_REQUESTER_PASSWORD=
EXCHANGE_RECIPIENT_EMAIL=
EXCHANGE_RECIPIENT_PASSWORD=

# Production URL for emails and redirects (set in Supabase Dashboard → Edge Functions → Secrets)
# SITE_URL and APP_URL must match EXPO_PUBLIC_WEB_URL in theramate-ios-client/.env for Stripe returns.
# Example: SITE_URL=https://theramate.co.uk  APP_URL=https://theramate.co.uk

# Web (peer-care-connect / Vercel) — VITE_* is bundled into public JS; use pk_* only
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_CONNECT_CLIENT_ID=ca_...

# Stripe secrets — Supabase Edge Function secrets ONLY (never VITE_* / never frontend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Mobile Expo (copy to theramate-ios-client/.env): EXPO_PUBLIC_WEB_URL, EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY

# Infobip (SMS) — server-only (set in Supabase Dashboard → Edge Functions → Secrets)
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://your-subdomain.api.infobip.com
INFOBIP_SMS_FROM=YourSenderId
