SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production URL for emails and redirects (set in Supabase Dashboard → Edge Functions → Secrets)
# SITE_URL and APP_URL must be set for production so email links point to your live domain, not localhost.
# Example: SITE_URL=https://theramate.co.uk  APP_URL=https://theramate.co.uk
