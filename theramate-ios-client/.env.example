# Copy to .env.local and fill in (never commit secrets).

# Supabase (same project as web)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (publishable key only — secret key stays on Supabase Edge Functions)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public web origin — must match apple-app-site-association / assetlinks + Stripe return URLs
EXPO_PUBLIC_WEB_URL=https://theramate.com

# Optional: PostHog
# EXPO_PUBLIC_POSTHOG_API_KEY=

# Optional: Sentry
# EXPO_PUBLIC_SENTRY_DSN=

# EAS — set after `eas init` (or paste into CI secrets). `app.config.js` reads this at build time.
# EAS_PROJECT_ID=
