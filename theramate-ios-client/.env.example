# Copy to `.env` in this folder for local Expo (`theramate-ios-client/.env`; gitignored).
# Expo inlines `EXPO_PUBLIC_*` at bundle time; `app.config.js` also passes them in `extra` for `expo-constants`.
# Values below match the Theramate Supabase project (anon key is public; RLS enforces access).
# Verified: project URL + legacy anon key via Supabase MCP (`get_project_url` + `get_publishable_keys`, project ref aikqnvltuwwgifuocvto).
# `app.config.js` loads `.env` via dotenv so `extra` gets these at config time; restart Expo after changes.

EXPO_PUBLIC_SUPABASE_URL=https://aikqnvltuwwgifuocvto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFpa3Fudmx0dXd3Z2lmdW9jdnRvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTU2MTk5NDgsImV4cCI6MjA3MTE5NTk0OH0.PJAKAkbAfp2PP4DXelMpIzhUZZUE5SVoKPzN0JJSRac

# Stripe (publishable key only — secret key stays on Supabase Edge Functions)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public web origin — must match apple-app-site-association / assetlinks + Stripe return URLs
EXPO_PUBLIC_WEB_URL=https://theramate.com

# Optional: PostHog
# EXPO_PUBLIC_POSTHOG_API_KEY=

# Optional: Sentry
# EXPO_PUBLIC_SENTRY_DSN=

# EAS — set after `eas init` (or paste into CI secrets). `app.config.js` reads this at build time.
# EAS_PROJECT_ID=
