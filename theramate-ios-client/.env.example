# Copy to `.env` in this folder for local Expo (`theramate-ios-client/.env`; gitignored).
# Expo inlines `EXPO_PUBLIC_*` at bundle time; `app.config.js` also passes them in `extra` for `expo-constants`.
# Values below match the Theramate Supabase project (anon key is public; RLS enforces access).
# Verified: project URL + legacy anon key via Supabase MCP (`get_project_url` + `get_publishable_keys`, project ref aikqnvltuwwgifuocvto).
# `app.config.js` loads `.env` via dotenv so `extra` gets these at config time; restart Expo after changes.

EXPO_PUBLIC_SUPABASE_URL=https://aikqnvltuwwgifuocvto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFpa3Fudmx0dXd3Z2lmdW9jdnRvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTU2MTk5NDgsImV4cCI6MjA3MTE5NTk0OH0.PJAKAkbAfp2PP4DXelMpIzhUZZUE5SVoKPzN0JJSRac

# Stripe — optional. Hosted Checkout + Connect onboarding do not require a publishable key in the app.
# Leave unset for hosted-only builds. Secret key stays in Supabase Edge Function secrets only.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public web origin — must match Supabase APP_URL / SITE_URL (Stripe success/cancel URLs)
# Use the same host your edge functions use (often theramate.co.uk in production).
EXPO_PUBLIC_WEB_URL=https://theramate.co.uk

# Optional: extra comma-separated origins for hosted WebView redirect parsing
# EXPO_PUBLIC_CHECKOUT_WEB_ORIGINS=https://theramate.com,https://www.theramate.com

# Optional: PostHog
# EXPO_PUBLIC_POSTHOG_API_KEY=

# Optional: Sentry
# EXPO_PUBLIC_SENTRY_DSN=

# EAS — optional override; `app.config.js` defaults to @theramate/theramate-client project id after `eas init`.
# EAS_PROJECT_ID=5ce9ebe4-a46b-4916-8f98-961efd6113da
