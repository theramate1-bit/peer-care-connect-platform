    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react-native-css-interop": "^0.2.2",
